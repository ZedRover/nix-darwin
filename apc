#!/usr/bin/env python3

import os
import re
import subprocess
import sys

CONFIG_FILE = os.environ.get(
    "APC_CONFIG_FILE",
    os.path.expanduser(
        "~/tools/nix-world/nix-darwin-kickstarter/minimal/modules/apps.nix"
    ),
)

LISTS = {
    "b": "brews",
    "c": "casks",
    "f": "fonts",
}

START_TAG = "### START {section} ###"
END_TAG = "### END {section} ###"
ITEM_PATTERN = re.compile(r'^\s*(?P<commented>#?)\s*"(?P<name>[^"]+)"\s*$')


def load_config():
    if not os.path.exists(CONFIG_FILE):
        print(f"配置文件 {CONFIG_FILE} 不存在！")
        sys.exit(1)
    with open(CONFIG_FILE, "r", encoding="utf-8") as f:
        return f.readlines()


def save_config(lines):
    with open(CONFIG_FILE, "w", encoding="utf-8") as f:
        f.writelines(lines)


def find_section(lines, section):
    start_line = None
    end_line = None
    for i, line in enumerate(lines):
        if START_TAG.format(section=section.upper()) in line:
            start_line = i
        if END_TAG.format(section=section.upper()) in line:
            end_line = i
    if start_line is None or end_line is None or start_line >= end_line:
        print(f"无法定位 {section} 区块！")
        sys.exit(1)
    return start_line + 1, end_line


def extract_items(lines, start, end):
    items = []
    for line in lines[start:end]:
        if not line.strip():
            continue
        match = ITEM_PATTERN.match(line)
        if not match:
            print(f"无法识别 {line.strip()}，请检查配置区块！")
            sys.exit(1)
        items.append(
            {
                "name": match.group("name"),
                "commented": bool(match.group("commented")),
            }
        )
    return items


def format_items(items):
    sorted_items = sorted(items, key=lambda item: item["name"].casefold())
    return [
        f'  {"#" if item["commented"] else ""}"{item["name"]}"\n'
        for item in sorted_items
    ]


def sort_all_sections(lines):
    for section in LISTS.values():
        start, end = find_section(lines, section)
        items = extract_items(lines, start, end)
        lines = lines[:start] + format_items(items) + lines[end:]
    return lines


def add_apps(section, apps):
    original_lines = load_config()
    lines = original_lines
    start, end = find_section(lines, section)
    items = extract_items(lines, start, end)

    for app in apps:
        existing = next((item for item in items if item["name"] == app), None)
        if existing is None:
            items.append({"name": app, "commented": False})
            print(f'"{app}" 已成功添加到 {section}。')
        elif existing["commented"]:
            existing["commented"] = False
            print(f'"{app}" 已在 {section} 中启用。')
        else:
            print(f'"{app}" 已存在于 {section}，跳过。')

    lines = lines[:start] + format_items(items) + lines[end:]
    lines = sort_all_sections(lines)
    if lines != original_lines:
        save_config(lines)
        run_nixfmt()


def delete_apps(apps):
    original_lines = load_config()
    lines = original_lines

    for app in apps:
        found = False
        for section in LISTS.values():
            start, end = find_section(lines, section)
            items = extract_items(lines, start, end)
            remaining_items = [item for item in items if item["name"] != app]
            if len(remaining_items) != len(items):
                lines = lines[:start] + format_items(remaining_items) + lines[end:]
                print(f"{app} 已从 {section} 中删除。")
                found = True
        if not found:
            print(f"{app} 不在任何列表中。")

    lines = sort_all_sections(lines)
    if lines != original_lines:
        save_config(lines)
        run_nixfmt()


def run_nixfmt():
    try:
        subprocess.run(["nixfmt", CONFIG_FILE], check=True)
        print("格式化完成：", CONFIG_FILE)
    except FileNotFoundError:
        print("未找到 nixfmt，跳过格式化。")


def print_usage():
    print("使用方法：")
    print("  添加软件: apc b|c|f 软件1 软件2 ...")
    print("  删除软件: apc del|d 软件1 软件2 ...")


def main():
    if len(sys.argv) < 3:
        print_usage()
        return
    op = sys.argv[1]
    args = sys.argv[2:]
    if op in LISTS:
        add_apps(LISTS[op], args)
    elif op in ["del", "d"]:
        delete_apps(args)
    else:
        print_usage()


if __name__ == "__main__":
    main()
